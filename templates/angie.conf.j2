worker_processes auto;

events {
    worker_connections 4096;
}

http {
    resolver 1.1.1.1 8.8.8.8 ipv6=off;

    acme_client le https://acme-v02.api.letsencrypt.org/directory
        challenge=http
        email={{ acme_email }};

    server {
        listen {{ angie_ssl_port }} ssl http2;
        server_name {{ domain_name }};
        acme le;

        ssl_certificate     $acme_cert_le;
        ssl_certificate_key $acme_cert_key_le;

        location / {
            proxy_http_version 1.1;
            
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";

            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Host $http_host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header Range $http_range;
            proxy_set_header If-Range $http_if_range;

            proxy_redirect off;
            proxy_pass http://{{ xui_upstream_host }}:{{ xui_upstream_port }};
        }

        location /{{ xui_subscription_path }}/ {
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";

            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Host $http_host;
            proxy_set_header X-Forwarded-Host $http_host;
            proxy_set_header X-Forwarded-Port $server_port;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header Range $http_range;
            proxy_set_header If-Range $http_if_range;

            proxy_redirect off;
            proxy_pass http://{{ xui_upstream_host }}:{{ xui_subscription_port }};
        }
    }
}